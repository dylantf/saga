{
  "name": "dylang",
  "displayName": "dylang",
  "description": "Language support for the dylang programming language",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "dylang",
        "aliases": [
          "dylang"
        ],
        "extensions": [
          ".dy"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dylang",
        "scopeName": "source.dylang",
        "path": "./syntaxes/dylang.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "dylang.restartServer",
        "title": "dylang: Restart Language Server"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
