{
  "name": "saga",
  "displayName": "saga",
  "description": "Language support for the saga programming language",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "saga",
        "aliases": [
          "saga"
        ],
        "extensions": [
          ".saga"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/saga-light.svg",
          "dark": "./icons/saga-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "saga",
        "scopeName": "source.saga",
        "path": "./syntaxes/saga.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "saga.restartServer",
        "title": "saga: Restart Language Server"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
