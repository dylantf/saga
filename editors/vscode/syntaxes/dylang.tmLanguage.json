{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "saga",
  "scopeName": "source.saga",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string-raw" },
    { "include": "#string-interp" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#effect-call" },
    { "include": "#keyword" },
    { "include": "#boolean" },
    { "include": "#operator" },
    { "include": "#type-name" },
    { "include": "#identifier" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.documentation.saga",
          "match": "#@.*$"
        },
        {
          "name": "comment.line.number-sign.saga",
          "match": "#.*$"
        }
      ]
    },
    "string-raw": {
      "name": "string.quoted.double.raw.saga",
      "begin": "@\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.raw.begin.saga" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.saga" }
      }
    },
    "string": {
      "name": "string.quoted.double.saga",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.saga",
          "match": "\\\\[ntr\\\\\"']"
        }
      ]
    },
    "string-interp": {
      "name": "string.quoted.double.interpolated.saga",
      "begin": "\\$\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.interpolated.begin.saga" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.saga" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.saga",
          "match": "\\\\[ntr\\\\\"'\\{]"
        },
        {
          "name": "meta.embedded.expression.saga",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.saga" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.saga" }
          },
          "patterns": [{ "include": "source.saga" }]
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.saga",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.saga",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "effect-call": {
      "name": "entity.name.function.effect-call.saga",
      "match": "\\b[a-z_][a-zA-Z0-9_']*!"
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.saga",
          "match": "\\b(if|then|else|case|when|with|return)\\b"
        },
        {
          "name": "keyword.declaration.saga",
          "match": "\\b(let|val|fun|pub|type|record|effect|handler|trait|impl|module|import|needs|where|resume)\\b"
        },
        {
          "name": "keyword.other.saga",
          "match": "\\b(as|for)\\b"
        }
      ]
    },
    "boolean": {
      "name": "constant.language.boolean.saga",
      "match": "\\b(True|False)\\b"
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.saga",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.saga",
          "match": "\\|>|<\\|"
        },
        {
          "name": "keyword.operator.compose.saga",
          "match": ">>|<<"
        },
        {
          "name": "keyword.operator.comparison.saga",
          "match": "==|!=|<=|>=|<(?![|>])|>(?![>])"
        },
        {
          "name": "keyword.operator.logical.saga",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.cons.saga",
          "match": "::"
        },
        {
          "name": "keyword.operator.concat.saga",
          "match": "<>"
        },
        {
          "name": "keyword.operator.range.saga",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.arithmetic.saga",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.saga",
          "match": "="
        }
      ]
    },
    "type-name": {
      "name": "entity.name.type.saga",
      "match": "\\b[A-Z][a-zA-Z0-9_']*\\b"
    },
    "identifier": {
      "name": "variable.other.saga",
      "match": "\\b[a-z_][a-zA-Z0-9_']*\\b"
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.saga",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.saga",
          "match": ":"
        },
        {
          "name": "punctuation.separator.dot.saga",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.pipe.saga",
          "match": "\\|"
        },
        {
          "name": "punctuation.bracket.round.saga",
          "match": "[()]"
        },
        {
          "name": "punctuation.bracket.square.saga",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.bracket.curly.saga",
          "match": "[{}]"
        }
      ]
    }
  }
}
