import Std.Test (describe, test, assert_eq, assert_true, assert_false, assert_just, assert_nothing)
import Std.Dict as Dict
import Std.List as List

describe "Dict" {

  describe "new" {
    test "creates empty dict" {
      Dict.new () |> Dict.size |> assert_eq 0
    }
  }

  describe "from_list and to_list" {
    test "round-trips" {
      let d = Dict.from_list [("a", 1), ("b", 2)]
      assert_eq (Dict.size d) 2
      assert_eq (Dict.get "a" d) (Just 1)
      assert_eq (Dict.get "b" d) (Just 2)
    }
  }

  describe "put and get" {
    test "inserts and retrieves" {
      let d = Dict.new () |> Dict.put "x" 42
      assert_eq (Dict.get "x" d) (Just 42)
    }

    test "overwrites existing key" {
      let d = Dict.from_list [("x", 1)] |> Dict.put "x" 2
      assert_eq (Dict.get "x" d) (Just 2)
    }

    test "missing key returns Nothing" {
      Dict.from_list [("x", 1)]
        |> Dict.get "y"
        |> assert_nothing
    }
  }

  describe "remove" {
    test "removes a key" {
      let d = Dict.from_list [("a", 1), ("b", 2)] |> Dict.remove "a"
      d |> Dict.get "a" |> assert_nothing
      d |> Dict.size |> assert_eq 1
    }

    test "removing missing key is a no-op" {
      Dict.from_list [("a", 1)]
        |> Dict.remove "z"
        |> Dict.size
        |> assert_eq 1
    }
  }

  describe "member" {
    test "true for present key" {
      Dict.from_list [("a", 1)] |> Dict.member "a" |> assert_true
    }

    test "false for missing key" {
      Dict.from_list [("a", 1)] |> Dict.member "z" |> assert_false
    }
  }

  describe "size" {
    test "empty dict" {
      Dict.new () |> Dict.size |> assert_eq 0
    }

    test "non-empty dict" {
      Dict.from_list [("a", 1), ("b", 2), ("c", 3)]
        |> Dict.size
        |> assert_eq 3
    }
  }

  describe "is_empty" {
    test "empty dict" {
      Dict.new () |> Dict.is_empty |> assert_true
    }

    test "non-empty dict" {
      Dict.from_list [("a", 1)] |> Dict.is_empty |> assert_false
    }
  }

  describe "keys and values" {
    test "returns keys" {
      Dict.from_list [("a", 1), ("b", 2)]
        |> Dict.keys
        |> List.sort
        |> assert_eq ["a", "b"]
    }

    test "returns values" {
      Dict.from_list [("a", 1), ("b", 2)]
        |> Dict.values
        |> List.sort
        |> assert_eq [1, 2]
    }
  }

  describe "map" {
    test "transforms values" {
      let d = Dict.from_list [("a", 1), ("b", 2)]
        |> Dict.map (fun v -> v * 10)
      assert_eq (Dict.get "a" d) (Just 10)
      assert_eq (Dict.get "b" d) (Just 20)
    }
  }

  describe "filter" {
    test "keeps matching entries" {
      let d = Dict.from_list [("a", 1), ("b", 2), ("c", 3)]
        |> Dict.filter (fun _k v -> v > 1)
      d |> Dict.size |> assert_eq 2
      d |> Dict.get "a" |> assert_nothing
      d |> Dict.get "b" |> assert_just
      d |> Dict.get "c" |> assert_just
    }
  }

  describe "fold" {
    test "accumulates over entries" {
      let total = Dict.from_list [("a", 1), ("b", 2), ("c", 3)]
        |> Dict.fold (fun acc _k v -> acc + v) 0
      assert_eq total 6
    }
  }

  describe "merge" {
    test "combines two dicts, second wins on conflicts" {
      let a = Dict.from_list [("x", 1), ("y", 2)]
      let b = Dict.from_list [("y", 99), ("z", 3)]
      let merged = Dict.merge a b
      assert_eq (Dict.get "x" merged) (Just 1)
      assert_eq (Dict.get "y" merged) (Just 99)
      assert_eq (Dict.get "z" merged) (Just 3)
    }
  }

  describe "update" {
    test "updates existing key" {
      Dict.from_list [("a", 10)]
        |> Dict.update "a" (fun v -> v + 5)
        |> Dict.get "a"
        |> assert_eq (Just 15)
    }

    test "missing key is a no-op" {
      let d = Dict.from_list [("a", 10)]
        |> Dict.update "z" (fun v -> v + 5)
      d |> Dict.size |> assert_eq 1
      d |> Dict.get "z" |> assert_nothing
    }
  }
}
