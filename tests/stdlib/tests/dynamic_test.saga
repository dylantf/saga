import Std.Dynamic (
  Dynamic,
  Decoder,
  DecodeError,
  decode,
  decode_field,
  decode_element,
  from_erlang,
  classify,
  string,
  int,
  float,
  bool,
  list_of,
  optional
)
import Std.List as List
import Std.Test (describe, test, assert_eq)

describe "Dynamic" {

  describe "classify" {
    test "classifies Int" {
      assert_eq (classify (from_erlang 42)) "Int"
    }

    test "classifies String" {
      assert_eq (classify (from_erlang "hello")) "String"
    }

    test "classifies Bool" {
      assert_eq (classify (from_erlang True)) "Bool"
    }

    test "classifies Float" {
      assert_eq (classify (from_erlang 1.5)) "Float"
    }

    test "classifies List" {
      assert_eq (classify (from_erlang [1, 2, 3])) "List"
    }

    test "classifies Map" {
      assert_eq (classify (from_erlang (Dict.from_list [("a", 1)]))) "Map"
    }
  }

  describe "decode_field" {
    test "decodes string and int fields" {
      let data =
        from_erlang (Dict.from_list [
          ("name", from_erlang "Alice"),
          ("age", from_erlang 30),
        ])

      let result = do {
        Ok(name) <- decode_field "name" string data
        Ok(age) <- decode_field "age" int data
        Ok((name, age))
      } else {
        Err(e) -> Err(e)
      }

      assert_eq result (Ok ("Alice", 30))
    }

    test "fails fast on first wrong type" {
      let data =
        from_erlang (Dict.from_list [
          ("name", from_erlang 42),
          ("age", from_erlang "not a number"),
        ])

      let result = do {
        Ok(name) <- decode_field "name" string data
        Ok(age) <- decode_field "age" int data
        Ok((name, age))
      } else {
        Err(e) -> Err(e)
      }

      assert_eq (Result.is_err result) True
    }

    test "reports missing field" {
      let data = from_erlang (Dict.from_list [("name", from_erlang "Alice")])

      let result = do {
        Ok(name) <- decode_field "name" string data
        Ok(age) <- decode_field "age" int data
        Ok((name, age))
      } else {
        Err(e) -> Err(e)
      }

      assert_eq (Result.is_err result) True
    }

    test "decodes float and bool fields" {
      let data =
        from_erlang (Dict.from_list [
          ("score", from_erlang 9.5),
          ("active", from_erlang True),
        ])

      let result = do {
        Ok(score) <- decode_field "score" float data
        Ok(active) <- decode_field "active" bool data
        Ok((score, active))
      } else {
        Err(e) -> Err(e)
      }

      assert_eq result (Ok (9.5, True))
    }
  }

  describe "decode_element" {
    test "decodes tuple elements" {
      let data = from_erlang ("Bob", 25)

      let result = do {
        Ok(name) <- decode_element 0 string data
        Ok(age) <- decode_element 1 int data
        Ok((name, age))
      } else {
        Err(e) -> Err(e)
      }

      assert_eq result (Ok ("Bob", 25))
    }
  }
}
