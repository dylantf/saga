module PanicTest

import Std.Test (Register, describe, test, assert_panics, assert_ok, assert_err)
import Std.List as List
import Std.Process (catch_panic)


pub fun tests : Unit -> Unit needs {Register}
tests () = {
  describe "panic recovery" (fun () -> {
    test "List.head on empty list panics" (fun () -> {
      assert_panics (fun () -> List.head [])
    })

    test "catch_panic returns Ok on success" (fun () -> {
      assert_ok (catch_panic (fun () -> 42))
    })

    test "catch_panic returns Err on panic" (fun () -> {
      assert_err (catch_panic (fun () -> panic "boom") : Result Int String)
    })

    test "panic inside multi-expression thunk" (fun () -> {
      assert_panics (fun () -> {
        let _ = 1 + 1
        panic "after some work"
      })
    })
  })
}
