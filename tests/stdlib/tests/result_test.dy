import Std.Test (describe, test, assert_eq, assert_true, assert_false, assert_ok, assert_err, assert_just, assert_nothing, assert_panics)
import Std.Result as Result

describe "Result" {

  describe "is_ok" {
    test "Ok is ok" {
      assert_true (Result.is_ok (Ok 1))
    }

    test "Err is not ok" {
      assert_false (Result.is_ok (Err "bad"))
    }
  }

  describe "is_err" {
    test "Err is err" {
      assert_true (Result.is_err (Err "bad"))
    }

    test "Ok is not err" {
      assert_false (Result.is_err (Ok 1))
    }
  }

  describe "map" {
    test "transforms Ok" {
      assert_eq (Result.map (fun x -> x * 2) (Ok 5)) (Ok 10)
    }

    test "Err stays Err" {
      assert_eq (Result.map (fun x -> x * 2) (Err "bad")) (Err "bad")
    }
  }

  describe "map_err" {
    test "transforms Err" {
      assert_eq (Result.map_err (fun e -> e <> "!") (Err "bad")) (Err "bad!")
    }

    test "Ok stays Ok" {
      assert_eq (Result.map_err (fun e -> e <> "!") (Ok 1)) (Ok 1)
    }
  }

  describe "unwrap" {
    test "returns value from Ok" {
      let r = if True then Ok 42 else Err "never"
      assert_eq (Result.unwrap r) 42
    }

    test "panics on Err" {
      let r = if False then Ok 0 else Err "oops"
      assert_panics (fun () -> Result.unwrap r)
    }
  }

  describe "unwrap_or" {
    test "returns value from Ok" {
      assert_eq (Result.unwrap_or 0 (Ok 42)) 42
    }

    test "returns default from Err" {
      assert_eq (Result.unwrap_or 0 (Err "bad")) 0
    }
  }

  describe "and_then" {
    test "chains on Ok" {
      let parse = fun s -> if s == "42" then Ok 42 else Err "parse error"
      assert_eq (Result.and_then parse (Ok "42")) (Ok 42)
    }

    test "short-circuits on Err" {
      assert_eq (Result.and_then (fun x -> Ok (x + 1)) (Err "bad")) (Err "bad")
    }
  }

  describe "or_else" {
    test "returns Ok when present" {
      assert_eq (Result.or_else (Ok 99) (Ok 1)) (Ok 1)
    }

    test "returns fallback on Err" {
      assert_eq (Result.or_else (Ok 99) (Err "bad")) (Ok 99)
    }
  }

  describe "to_maybe" {
    test "Ok becomes Just" {
      assert_eq (Result.to_maybe (Ok 42)) (Just 42)
    }

    test "Err becomes Nothing" {
      assert_nothing (Result.to_maybe (Err "bad"))
    }
  }

  describe "flatten" {
    test "flattens nested Ok" {
      assert_eq (Result.flatten (Ok (Ok 42))) (Ok 42)
    }

    test "flattens nested Err" {
      assert_eq (Result.flatten (Ok (Err "inner"))) (Err "inner")
    }

    test "outer Err stays Err" {
      assert_eq (Result.flatten (Err "outer")) (Err "outer")
    }
  }
}
