import Std.Test (describe, test, assert_eq, assert_true, assert_false, assert_ok, assert_err, assert_just, assert_nothing, assert_panics)
import Std.Result as Result

describe "Result" {

  describe "is_ok" {
    test "Ok is ok" {
      let r = if True then Ok 1 else Err "e"
      assert_true (Result.is_ok r)
    }

    test "Err is not ok" {
      let r = if False then Ok 0 else Err "bad"
      assert_false (Result.is_ok r)
    }
  }

  describe "is_err" {
    test "Err is err" {
      let r = if False then Ok 0 else Err "bad"
      assert_true (Result.is_err r)
    }

    test "Ok is not err" {
      let r = if True then Ok 1 else Err "e"
      assert_false (Result.is_err r)
    }
  }

  describe "map" {
    test "transforms Ok" {
      let r = if True then Ok 5 else Err "e"
      assert_eq (Result.map (fun x -> x * 2) r) (if True then Ok 10 else Err "e")
    }

    test "Err stays Err" {
      let r = if False then Ok 0 else Err "bad"
      assert_eq (Result.map (fun x -> x * 2) r) (if False then Ok 0 else Err "bad")
    }
  }

  describe "map_err" {
    test "transforms Err" {
      let r = if False then Ok 0 else Err "bad"
      assert_eq (Result.map_err (fun e -> e <> "!") r) (if False then Ok 0 else Err "bad!")
    }

    test "Ok stays Ok" {
      let r = if True then Ok 1 else Err "e"
      assert_eq (Result.map_err (fun e -> e <> "!") r) (if True then Ok 1 else Err "e")
    }
  }

  describe "unwrap" {
    test "returns value from Ok" {
      let r = if True then Ok 42 else Err "e"
      assert_eq (Result.unwrap r) 42
    }

    test "panics on Err" {
      assert_panics (fun () -> {
        let r = if False then Ok 0 else Err "oops"
        Result.unwrap r
      })
    }
  }

  describe "unwrap_or" {
    test "returns value from Ok" {
      let r = if True then Ok 42 else Err "e"
      assert_eq (Result.unwrap_or 0 r) 42
    }

    test "returns default from Err" {
      let r = if False then Ok 0 else Err "bad"
      assert_eq (Result.unwrap_or 0 r) 0
    }
  }

  describe "and_then" {
    test "chains on Ok" {
      let r = if True then Ok 42 else Err "e"
      let f = fun x -> if x == 42 then Ok 100 else Err "no"
      assert_ok (Result.and_then f r)
    }

    test "short-circuits on Err" {
      let r = if False then Ok 0 else Err "bad"
      assert_err (Result.and_then (fun x -> Ok (x + 1)) r)
    }
  }

  describe "or_else" {
    test "returns Ok when present" {
      let r = if True then Ok 1 else Err "e"
      assert_ok (Result.or_else (Ok 99) r)
    }

    test "returns fallback on Err" {
      let r = if False then Ok 0 else Err "bad"
      let fallback = if True then Ok 99 else Err "e"
      assert_eq (Result.or_else fallback r) fallback
    }
  }

  describe "to_maybe" {
    test "Ok becomes Just" {
      let r = if True then Ok 42 else Err "e"
      assert_eq (Result.to_maybe r) (Just 42)
    }

    test "Err becomes Nothing" {
      let r = if False then Ok 0 else Err "bad"
      assert_nothing (Result.to_maybe r)
    }
  }

  describe "from_maybe" {
    test "Just becomes Ok" {
      let r = Result.from_maybe "missing" (Just 42)
      assert_ok r
    }

    test "Nothing becomes Err" {
      let n = if False then Just 0 else Nothing
      let r = Result.from_maybe "missing" n
      assert_err r
    }
  }

  describe "flatten" {
    test "flattens nested Ok" {
      let inner = if True then Ok 42 else Err "e"
      let outer = if True then Ok inner else Err "e"
      assert_eq (Result.flatten outer) inner
    }

    test "flattens nested Err" {
      let inner = if False then Ok 0 else Err "inner"
      let outer = if True then Ok inner else Err "e"
      assert_err (Result.flatten outer)
    }

    test "outer Err stays Err" {
      let inner = if True then Ok 0 else Err "e"
      let outer = if False then Ok inner else Err "outer"
      assert_err (Result.flatten outer)
    }
  }
}
