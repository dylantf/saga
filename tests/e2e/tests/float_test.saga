import Std.Test (describe, test, assert_eq)

describe "Float" {
  describe "parse" {
    test "parses decimal" {
      assert_eq (Float.parse "2.5") (Just 2.5)
    }

    test "parses integer-like string as float" {
      assert_eq (Float.parse "2") (Just 2.0)
    }

    test "parses negative integer-like" {
      assert_eq (Float.parse "-7") (Just (-7.0))
    }

    test "parses negative decimal" {
      assert_eq (Float.parse "-1.5") (Just (-1.5))
    }

    test "parses zero" {
      assert_eq (Float.parse "0") (Just 0.0)
    }

    test "rejects empty string" {
      assert_eq (Float.parse "") Nothing
    }

    test "rejects non-numeric" {
      assert_eq (Float.parse "abc") Nothing
    }

    test "rejects trailing garbage" {
      assert_eq (Float.parse "2.5abc") Nothing
    }

    test "rejects integer with trailing garbage" {
      assert_eq (Float.parse "2abc") Nothing
    }
  }
}
