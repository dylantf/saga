module FundepDerivedCrossModuleTest

import SelectableLibTest (Col, Projection, User, Users, users, render_projection, select)
import Std.Test (Testing, describe, test, assert_eq)

# Regression: constructing a derived fundep dictionary (`deriving (Selectable
# User)` on `Users`) from a *different* module than the one defining the impls.
#
# Two cross-module bugs combined here:
#   1. The dict-constructor arity was exported from a crude `where_apps.len()`
#      count, which overcounts where-apps whose first type arg is concrete (the
#      synthesized `Generic Users __rep` / `Generic User __rep`). `make_fun`
#      then referenced the dict at arity 3 while it was defined at arity 1.
#   2. The fundep where-app sub-dict (`Selectable __row_rep`) was never applied,
#      because `impl_where_app_dict_params` is empty for imported impls — the
#      dict was passed as a bare constructor reference instead of the built
#      tuple, crashing in `element/2`.

pub fun tests : Unit -> Unit needs {Testing}
tests () = {
  describe "derived fundep dict constructed cross-module" (fun () -> {
    test "projects an anonymous record nesting a derived Users value" (fun () -> {
      let cols = (select ({ user: users, title: Col "Hello" }) : Projection { user: User, title: String })
      assert_eq (render_projection cols) "title:col,user:id:col,name:col"
    })
  })
}
