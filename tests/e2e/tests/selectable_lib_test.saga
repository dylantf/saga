module SelectableLibTest

# Helper + local sanity test for the cross-module regression exercised by
# FundepDerivedCrossModuleTest. The trait, the building-block impls, and the
# `deriving (Selectable User)` records live here; the sibling test module
# imports them and is thereby forced to construct the derived dictionary
# cross-module (the path that used to crash).

import Std.Generic (Generic, Leaf, Labeled, And, Record)
import Std.Test (Testing, describe, test, assert_eq)

pub type Col a = Col a

pub record User {
  id: Int,
  name: String,
} deriving (Generic)

pub record Users {
  id: Col Int,
  name: Col String,
} deriving (Selectable User)

pub trait Selectable selection row | selection -> row {
  fun project : selection -> Projection row
}

pub type Projection a = Projection String

pub fun render_projection : Projection a -> String
render_projection p = case p { Projection value -> value }

pub fun map : (a -> b) -> Projection a -> Projection b
map _ p = case p { Projection value -> Projection value }

fun zip_projection : Projection a -> Projection b -> Projection (a, b)
zip_projection left right = {
  let Projection left_value = left
  let Projection right_value = right
  Projection (left_value <> "," <> right_value)
}

impl Selectable a for Col a {
  project _ = Projection "col"
}

impl Selectable (Leaf row) for Leaf selection where {selection: Selectable row} {
  project selection = case selection { Leaf value -> project value |> map Leaf }
}

impl Selectable (Labeled n out) for Labeled n field
  where {n: KnownSymbol, field: Selectable out}
{
  project selection = case selection {
    Labeled field -> project field |> map Labeled |> prefix (symbol_name (Proxy : Proxy n))
  }
}

fun prefix : String -> Projection a -> Projection a
prefix label projection = case projection { Projection value -> Projection (label <> ":" <> value) }

impl Selectable (And left_out right_out) for And left right
  where {left: Selectable left_out, right: Selectable right_out}
{
  project selection = case selection {
    And left right -> zip_projection (project left) (project right) |> map (fun selected -> {
      let (left_value, right_value) = selected
      And left_value right_value
    })
  }
}

impl Selectable (Record out) for Record fields where {fields: Selectable out} {
  project selection = case selection {
    Record name fields -> project fields |> map (fun out -> Record name out)
  }
}

pub fun select : selection -> Projection row
  where { selection: Generic selection_rep, selection_rep: Selectable row_rep, row: Generic row_rep }
select selection = project (to selection) |> map from

pub fun users : Users
users = Users { id: Col 1, name: Col "Alice" }

pub fun tests : Unit -> Unit needs {Testing}
tests () = {
  describe "Selectable projection (in-module)" (fun () -> {
    test "projects a plain derived record" (fun () -> {
      assert_eq (render_projection (select users : Projection User)) "id:col,name:col"
    })
  })
}
