module EffectOpConstraintLibTest

# Helper for effect_op_constraint_cross_module_test: a cross-module effect whose
# operation carries a method-level `where` constraint (`a: Show`). The importing
# test module's `op!` call site must thread the constraint's dictionary to the
# handler. Cross-module, the op's constraint var name was missing from the
# importer's `where_bound_var_names`, so the dicts were dropped and the handler
# was invoked with too few arguments (an arity crash).

import Std.Test (Testing, describe, test, assert_eq)

pub effect Describe {
  fun describe : a -> String where {a: Show}
}

pub handler show_it for Describe {
  describe x = resume (show x)
}

pub fun tests : Unit -> Unit needs {Testing}
tests () = {
  describe "effect op constraint (in-module)" (fun () -> {
    test "handles a constrained op in its defining module" (fun () -> {
      let s = { describe! 7 } with show_it
      assert_eq s "7"
    })
  })
}
