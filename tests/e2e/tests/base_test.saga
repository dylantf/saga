import Std.Test (describe, test, assert_eq, assert_true, assert_false)

describe "basics" {

  describe "arithmetic" {
    test "addition" {
      assert_eq (1 + 2) 3
    }

    test "subtraction" {
      assert_eq (10 - 3) 7
    }

    test "multiplication" {
      assert_eq (4 * 5) 20
    }

    test "integer division" {
      assert_eq (7 / 2) 3
    }

    test "modulo" {
      assert_eq (10 % 3) 1
    }
  }

  describe "booleans" {
    test "and" {
      assert_true (True && True)
      assert_false (True && False)
    }

    test "or" {
      assert_true (True || False)
      assert_false (False || False)
    }

    test "equality" {
      assert_true (1 == 1)
      assert_false (1 == 2)
    }

    test "comparison" {
      assert_true (1 < 2)
      assert_true (3 > 2)
      assert_true (2 <= 2)
      assert_true (2 >= 2)
    }
  }

  describe "strings" {
    test "concatenation" {
      assert_eq ("hello" <> " " <> "world") "hello world"
    }

    test "interpolation" {
      let name = "saga"
      assert_eq $"hello {name}" "hello saga"
    }
  }

  describe "let bindings" {
    test "simple binding" {
      let x = 42
      assert_eq x 42
    }

    test "binding with expression" {
      let x = 2 + 3
      assert_eq x 5
    }
  }

  describe "functions" {
    test "lambda" {
      let double = fun x -> x * 2
      assert_eq (double 5) 10
    }

    test "pipe" {
      let result = 5 |> fun x -> x * 2 |> fun x -> x + 1
      assert_eq result 11
    }
  }

  describe "lists" {
    test "literal" {
      assert_eq [1, 2, 3] [1, 2, 3]
    }

    test "concatenation" {
      assert_eq ([1, 2] <> [3, 4]) [1, 2, 3, 4]
    }

    test "cons" {
      assert_eq (1 :: 2 :: 3 :: []) [1, 2, 3]
    }

    test "comprehension" {
      assert_eq ([x * 2 | x <- [1, 2, 3]]) [2, 4, 6]
    }

    test "comprehension with filter" {
      assert_eq ([x | x <- [1, 2, 3, 4, 5], x > 3]) [4, 5]
    }
  }

  describe "tuples" {
    test "pair" {
      let p = (1, "hello")
      assert_eq p (1, "hello")
    }

    test "triple" {
      assert_eq (1, 2, 3) (1, 2, 3)
    }
  }

  describe "pattern matching" {
    test "case on int" {
      let result = case 2 {
        1 -> "one"
        2 -> "two"
        _ -> "other"
      }
      assert_eq result "two"
    }

    test "case on list" {
      let result = case [1, 2, 3] {
        [] -> "empty"
        [_] -> "one"
        _ :: _ -> "many"
      }
      assert_eq result "many"
    }

    test "let destructuring" {
      let (a, b) = (10, 20)
      assert_eq (a + b) 30
    }
  }
}
