module Main

import Lib (Options, Encodable)

type Event =
  | Heartbeat
  | Login Int
  | Click Int Int
  deriving (Encodable)

main () = {
  let h = Lib.options 10
  let heartbeat = Lib.override_options Heartbeat with h
  let login = Lib.override_options (Login 5) with h
  dbg (show (heartbeat + login))
}
