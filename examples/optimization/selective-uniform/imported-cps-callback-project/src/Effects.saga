module Effects

pub effect ReadInt
  fun read : Unit -> Int

pub fun read_value : Unit -> Int needs {ReadInt}
read_value () = read! ()

pub fun read_again : Unit -> Int needs {ReadInt}
read_again () = read! ()

pub fun pure_value : Unit -> Int
pure_value () = 41

pub fun apply_eff : (Unit -> Int needs {ReadInt}) -> Int needs {ReadInt}
apply_eff f =
  let g = f
  g ()

pub handler forty_one for ReadInt
  read () = resume 41
