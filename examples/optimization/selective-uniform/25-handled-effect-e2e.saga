import Std.IO.Unsafe (print_stdout)

effect ReadInt {
  fun read : Unit -> Int
}

handler forty_one for ReadInt {
  read () = resume 41
}

fun answer : Unit -> Int
answer () = {
  let value = read! () with forty_one
  value + 1
}

fun main : Unit -> Unit
main () =
  if answer () == 42 then print_stdout "ok\n"
  else print_stdout "bad\n"
