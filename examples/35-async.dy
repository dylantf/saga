import Std.Actor (beam_actor)
import Std.Async (Async, async_handler)

fun run : Unit -> List Int needs {Async}
run () = {
  let f1 = async! (fun () -> 1)
  let f2 = async! (fun () -> 2)
  let f3 = async! (fun () -> 3)
  Async.all [f1, f2, f3]
}

main () = {
  let results = run () with {async_handler, beam_actor}
  dbg results
}
