# Multiple function heads with guards are supported and checked for exhaustiveness
fizzbuzz n | n % 15 == 0 = "FizzBuzz"
fizzbuzz n | n % 3 == 0 = "Fizz"
fizzbuzz n | n % 5 == 0 = "Buzz"
fizzbuzz n = show n

loop i max = if i > max then () else {
  fizzbuzz i |> println
  loop (i + 1) max
}

main () = loop 1 100
