# Test named effect instances (Layer 2)

effect State s {
  fun get : Unit -> s
  fun put : s -> Unit
}

handler make_state for State Int {
  get () = resume 0
  put _ = resume ()
}

# Function with named effect instances in needs
fun transfer : Int -> Unit needs {from: State Int, to: State Int}
transfer amount = {
  let balance = from.get! ()
  from.put! (balance - amount)
  to.put! (to.get! () + amount)
}

main () = ()
