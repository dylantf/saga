effect State s {
  fun get : Unit -> s
  fun put : s -> Unit
}

fun make_state : Unit -> Handler (State s)
make_state () =
  handler for State s {
    get () = fun s -> (resume s) s
    put next = fun _ -> (resume ()) next
    return value = fun s -> (value, s)
  }

fun deposit : Int -> Int needs {account: State Int}
deposit amount {account} = {
  let balance = account.get! ()
  let updated = balance + amount
  account.put! updated
  updated
}

fun transfer : Int -> (Int, Int) needs {from: State Int, to: State Int}
transfer amount {from, to} = {
  let from_balance = from.get! ()
  let to_balance = deposit 0 with {
    account: to,
  }
  from.put! (from_balance - amount)
  to.put! (to_balance + amount)
  (from_balance - amount, to_balance + amount)
}

main () = {
  handle checking = make_state ()
  handle savings = make_state ()
  let result = transfer 30 with {
    from: checking,
    to: savings,
  }
  let (inner, from_final) = result 100
  let (balances, to_final) = inner 20

  let _ = dbg balances
  let _ = dbg from_final
  let _ = dbg to_final
}
