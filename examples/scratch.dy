import Std.Fail (Fail)

effect Log {
  fun log : String -> Unit
}

handler silent for Log {
  log _ = resume ()
}

handler swallow for Fail String {
  fail _ = 0
}

fun outer : Unit -> Unit needs {Log}
outer () = {
  let result = inner () with swallow
  log! (show result)
}

fun inner : Unit -> Int needs {Fail String}
inner () = {
  fail! "boom"
}

main () = {
  outer () with silent
  # outer ()
  dbg "done"
}
