fun run : (f: a -> b needs {..e}) -> (x: a) -> b needs {..e}
run f x = f x

fn1 a = dbg a

fn2 = dbg

main () = {
  let fn3 a = println a
  let fn4 = println

  run fn1 "fn1 Hello"
  run fn2 "fn2 Hello"
  run fn3 "fn3 Hello"
  run fn4 "fn4 Hello"

  List.iter fn1 ["iter fn1 1", "iter fn1 2"]
  List.iter fn2 ["iter fn2 1", "iter fn2 2"]
  List.iter fn3 ["iter fn3 1", "iter fn3 2"]
  List.iter fn4 ["iter fn4 1", "iter fn4 2"]
} with {console}
