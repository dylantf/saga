effect Inner {
  fun inner_op () -> Unit
}

effect Outer {
  fun outer_op () -> Unit
}

# Function that handles Inner internally and uses Outer
fun middle (body: () -> Unit needs {Inner}) -> Unit needs {Outer}
middle body = {
  let result = { body () } with {
    inner_op () = {
      resume ()
      "handled"
    }
    return _ = "ok"
  }
  outer_op! ()
}

main () = {
  middle (fun () -> {
    inner_op! ()
  })
} with {
  outer_op () = {
    print "outer handled"
    resume ()
  }
}
