# Test named effect instances end-to-end

effect Log {
  fun log : String -> Unit
}

handler console_log for Log {
  log msg = {
    println msg
    resume ()
  }
}

handler prefix_log for Log {
  log msg = {
    println $"[PREFIX] {msg}"
    resume ()
  }
}

fun greet : String -> Unit needs {out: Log}
greet name {out} = out.log! $"hello {name}"

main () = {
  handle c = console_log
  handle p = prefix_log

  greet "world" with {
    out: c,
  }
  greet "world" with {
    out: p,
  }
}
