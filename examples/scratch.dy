import Std.Array

main () = {
  let arr = Array.from_list [10, 20, 30, 40, 50]
  dbg (Array.size arr)
  dbg (Array.get 2 arr)
  dbg (Array.get 99 arr)
  let arr2 = Array.set 2 99 arr
  dbg (Array.to_list arr2)
  let arr3 = Array.map (fun x -> x * 2) arr
  dbg (Array.to_list arr3)
  let sum = Array.foldl Int.add 0 arr
  dbg sum
}
