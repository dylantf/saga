import Std.Fail (Fail)

effect Recorder a {
  fun log_state : (entity: a) -> Unit
}

handler recording for Recorder a where {a: Show} {
  log_state entity = {
    let _ = show entity
    resume ()
  }
}

run f = f ()

main () = {
  # Bug: _ does not match (). Only works when called with ().
  let result = run (fun _ -> {
    let result = {
      log_state! 42
      log_state! 99
      "done"
    } with recording
    result
  })
  dbg result
}
