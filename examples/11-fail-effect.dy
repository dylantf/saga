effect Fail {
  fun fail (msg: String) -> a
}

handler log_failure for Fail {
  fail msg = print ("Error: " <> msg)
}

fun safe_div (x: Int) (y: Int) -> Int needs {Fail}
safe_div x 0 = fail! "division by zero"
safe_div x y = x / y

main () = {
  let a = (safe_div 10 2) with log_failure
  print a
  let b = (safe_div 10 0) with log_failure
  print b
}
