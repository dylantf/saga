module Main

import Std.Set

pub fun main : Unit -> Unit
main () = {
  let s =
    Set.new ()
    |> Set.insert 1
    |> Set.insert 2
    |> Set.insert 3
    |> Set.insert 2

  dbg (show (Set.size s))

  let s2 = Set.from_list [3, 4, 5]

  let u = Set.union s s2
  dbg (show (Set.size u))

  let i = Set.intersection s s2
  dbg (show (Set.size i))

  let d = Set.difference s s2
  dbg (show (Set.size d))

  dbg (show (Set.member 2 s))
  dbg (show (Set.member 99 s))

  dbg (show (Set.is_empty s))
  dbg (show (Set.is_empty (Set.new ())))

  let doubled = Set.map (fun x -> x * 2) s
  dbg (show (Set.size doubled))

  let evens = Set.filter (fun x -> x % 2 == 0) s
  dbg (show (Set.size evens))

  let total = Set.fold (fun acc x -> acc + x) 0 s
  dbg (show total)

  dbg (show (Set.is_subset (Set.from_list [1, 2]) s))
  dbg (show (Set.is_subset (Set.from_list [1, 99]) s))

  let sym = Set.symmetric_difference s s2
  dbg (show (Set.size sym))

  let removed = Set.remove 2 s
  dbg (show (Set.size removed))
}
