module Main

import MathLib (add, double)

pub fun main : Unit -> Unit
main () = {
  println (show (add 10 20))
  println (show (double 7))
  println (show (double 14))
  println (show (MathLib.add 100 200))

  let pair = (42, "hello")
  println (show (fst pair))
  println (snd pair)

  println (show (multiply! 2 3)) with math_handler

  println ("Hello, " <> "\"" <> "Dave" <> "\"")
}
