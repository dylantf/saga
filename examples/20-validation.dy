type Validation e a {
  Valid(a)
  Invalid(e)
}

val_map f v = case v {
  Valid(x) -> Valid(f x)
  Invalid(errs) -> Invalid(errs)
}

val_ap func x = case func {
  Valid(f) -> case x {
    Valid(v) -> Valid(f v)
    Invalid(errs) -> Invalid(errs)
  }
  Invalid(e1) -> case x {
    Valid(_) -> Invalid(e1)
    Invalid(e2) -> Invalid(append e1 e2)
  }
}

# --- Validators ---

require_non_empty label s =
  if s == "" then Invalid([$"{label} is required"])
  else Valid(s)

require_min_age min age =
  if age < min then Invalid([$"age must be at least {min}"])
  else Valid(age)

# --- Domain types ---

record UserInput {
  name: String,
  age: Int,
}

record ValidUser {
  name: String,
  age: Int,
}

# Note: Functions must be annotated due to two record types with same properties.
# The types cannot be narrowed though pattern alone
fun validate_user (input: UserInput) -> Validation (List String) ValidUser
validate_user input = {
  let name_v = require_non_empty "name" input.name
  let age_v = require_min_age 18 input.age
  let build = fun n -> fun a -> ValidUser { name: n, age: a }
  val_ap (val_map build name_v) age_v
}

# --- Display ---

show_errors errs = foldl (fun acc e -> acc <> $"\n  - {e}") "" errs

fun show_result (r: Validation (List String) ValidUser) -> String
show_result r = case r {
  Valid(user) -> $"Valid: {user.name}, age {user.age}"
  Invalid(errs) -> $"Invalid: {show_errors errs}"
}

# --- Main ---

main () = {
  validate_user UserInput { name: "Alice", age: 25 } |> show_result |> print
  validate_user UserInput { name: "", age: 25 } |> show_result |> print
  validate_user UserInput { name: "Bob", age: 15 } |> show_result |> print
  validate_user UserInput { name: "", age: 15 } |> show_result |> print
}
