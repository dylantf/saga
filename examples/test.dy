import Std.Actor


effect Log {
  fun log (msg: String) -> Unit
}

handler console_log for Log {
  log msg -> {
    print msg
    resume ()
  }
}

fun worker () -> () needs {Log}
worker () = ()

foo () = 42

main () = {
  spawn! (fun () -> worker ())
  sleep! 100
  foo ()
  foo ()
} with { console_log, beam_actor }
