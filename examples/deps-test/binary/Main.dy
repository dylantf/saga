module Main

import MathLib (add, double, square)

fun roll_dice : Unit -> Int needs {Rand}
roll_dice () = random_int! 1 6

pub fun main : Unit -> Unit
main () = {
  let result = add 3 4
  println (show result)

  let doubled = double 5
  println (show doubled)

  let squared = square 6
  println (show squared)

  let die = roll_dice () with real_rand
  println $"rolled a {show die}"
}
