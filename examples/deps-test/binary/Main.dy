module Main

import MathLib (add, double, square, Rand, real_rand)

fun roll_dice : Unit -> Int needs {Rand}
roll_dice () = random_int! 1 6

# Direct FFI to hex dep
@external("erlang", "base64url", "encode")
fun b64_encode : String -> String

# Bridge that calls into hex dep
@external("erlang", "base64_bridge", "round_trip")
fun b64_round_trip : String -> (String, String)

# NIF — rebar3-compiled hex dep (via bridge for type mapping)
@external("erlang", "argon2_bridge", "hash")
fun argon2_hash : String -> String

pub fun main : Unit -> Unit
main () = {
  let result = add 3 4
  println (show result)

  let doubled = double 5
  println (show doubled)

  let squared = square 6
  println (show squared)

  let die = roll_dice () with real_rand
  println $"rolled a {show die}"

  # Direct call to hex dep
  let encoded = b64_encode "hello from hex!"
  println $"encoded: {encoded}"

  # Bridge call that uses hex dep internally
  let (enc, dec) = b64_round_trip "round trip test"
  println $"bridge encoded: {enc}"
  println $"bridge decoded: {dec}"

  # NIF call via rebar3-compiled hex dep
  let hashed = argon2_hash "my_password"
  println $"argon2 hash: {hashed}"
} with {console}
