effect Outer {
  fun register : (Unit -> Unit needs {Inner}) -> Unit
}

effect Inner {
  fun ping : Unit -> Unit
}

fun do_stuff : Unit -> Unit needs {Outer}
do_stuff () = register! (fun () -> ping! ())

handler collect_outer for Outer {
  register _ = resume ()
  return _ = []
}

main () = {
  let bodies = do_stuff () with collect_outer
  println (show (List.length bodies)) with console
}
