effect Foo {
  fun foo : Unit -> Int
}
effect Bar {
  fun bar : Unit -> Int
}

fun do_work : (Unit -> Int needs {..a}) -> (Unit -> Int needs {..b}) -> Int
  needs {..a, ..b}
do_work a b = {
  let res_a = a ()
  let res_b = b ()
  res_a + res_b
}

main () = {
  let res = do_work (fun () -> foo! ()) (fun () -> bar! ())
  dbg res
} with {
  foo () = resume 42
  bar () = resume 3
}
