#@ Boolean operations.
module Std.Bool

import Std.Base (Show, Debug, Ord, Semigroup, Enum)

impl Show for Bool {
  show b = case b {
    True -> "True"
    False -> "False"
  }
}

impl Debug for Bool {
  debug b = case b {
    True -> "True"
    False -> "False"
  }
}

#@ Negates a boolean value.
pub fun not : Bool -> Bool
not True = False
not False = True


