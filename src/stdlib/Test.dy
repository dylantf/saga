module Std.Test

import Std.Base
import Std.IO (print, println)
import Std.Process
import Std.List

pub effect Assert {
  fun assert : (ok: Bool) -> (msg: String) -> Unit
}

type TestMode = Normal | OnlyMode | SkipMode

type TestEntry = TestCase(String, TestMode) | GroupStart(String) | GroupEnd

pub effect TestRunner {
  fun report_test : (name: String) -> (failures: List String) -> (mode: TestMode) -> Unit
  fun enter_group : (name: String) -> Unit
  fun leave_group : Unit -> Unit
}

record TestState {
  passed: Int,
  failed: Int,
  skipped: Int,
  depth: Int,
  has_only: Bool,
}

fun make_indent : (n: Int) -> String
make_indent n =
  if n <= 0 then ""
  else "  " <> make_indent (n - 1)

fun run_body : (body: () -> Unit needs {Assert}) -> List String
run_body body = {
  let (_, failures) = { body () } with {
    assert ok msg =
      if ok then {
        let (val, errs) = resume ()
        (val, errs)
      } else {
        let (val, errs) = resume ()
        (val, msg :: errs)
      }
    return val = (val, [])
  }
  failures
}

#@ Run a test.
pub fun test : (name: String) -> (body: () -> Unit needs {Assert}) -> Unit needs {TestRunner}
test name body = {
  let failures = run_body body
  report_test! name failures Normal
}

#@ Run a focused test. When any test uses `only`, all other tests are skipped.
pub fun only : (name: String) -> (body: () -> Unit needs {Assert}) -> Unit needs {TestRunner}
only name body = {
  let failures = run_body body
  report_test! name failures OnlyMode
}

#@ Skip a test. The body is never executed.
pub fun skip : (name: String) -> (body: () -> Unit needs {Assert}) -> Unit needs {TestRunner}
skip name body = report_test! name [] SkipMode

#@ Group tests under a label.
pub fun describe : (name: String) -> (body: () -> Unit needs {TestRunner}) -> Unit needs {TestRunner}
describe name body = {
  enter_group! name
  body ()
  leave_group! ()
}

#@ Collecting handler (pass 1). Records test entries, discards results.
handler collect_handler for TestRunner {
  report_test name failures mode = {
    let k = resume ()
    fun entries -> k (TestCase(name, mode) :: entries)
  }
  enter_group name = {
    let k = resume ()
    fun entries -> k (GroupStart(name) :: entries)
  }
  leave_group () = {
    let k = resume ()
    fun entries -> k (GroupEnd :: entries)
  }
  return _ = fun entries -> entries
}

#@ Executing handler (pass 2). Renders results, skips non-only tests if has_only is set.
pub handler exec_handler for TestRunner {
  report_test name failures mode = {
    let k = resume ()
    fun state -> {
      let indent = make_indent state.depth
      let should_skip = case mode {
        SkipMode -> True
        Normal -> state.has_only
        OnlyMode -> False
      }
      if should_skip then {
        println (indent <> "\x1b[33m○\x1b[0m " <> name <> " (skipped)")
        k { state | skipped: state.skipped + 1 }
      } else {
        case failures {
          [] -> {
            println (indent <> "\x1b[32m✓\x1b[0m " <> name)
            k { state | passed: state.passed + 1 }
          }
          h :: _ -> {
            println (indent <> "\x1b[31m✗\x1b[0m " <> name)
            println (indent <> "    " <> h)
            k { state | failed: state.failed + 1 }
          }
        }
      }
    }
  }
  enter_group name = {
    let k = resume ()
    fun state -> {
      let indent = make_indent state.depth
      println (indent <> name)
      k { state | depth: state.depth + 1 }
    }
  }
  leave_group () = {
    let k = resume ()
    fun state -> k { state | depth: state.depth - 1 }
  }
  return _ = fun state -> state
}

fun reverse_entries : (acc: List TestEntry) -> (xs: List TestEntry) -> List TestEntry
reverse_entries acc xs = case xs {
  [] -> acc
  h :: t -> reverse_entries (h :: acc) t
}

fun has_only_entry : TestEntry -> Bool
has_only_entry entry = case entry {
  TestCase(_, OnlyMode) -> True
  _ -> False
}

#@ Run a test suite with two-pass collect-then-execute.
#@ Pass 1 collects test metadata to check for `only`.
#@ Pass 2 executes, skipping non-only tests if any only was found.
pub fun run_collected : (body: () -> Unit needs {TestRunner}) -> Unit
run_collected body = {
  # Pass 1: collect entries (bodies run but results discarded)
  let entries_fn = { body () } with collect_handler
  let entries = reverse_entries [] (entries_fn [])
  let found_only = List.any has_only_entry entries

  # Pass 2: execute for real
  let state_fn = { body () } with exec_handler
  let final = state_fn (TestState { passed: 0, failed: 0, skipped: 0, depth: 0, has_only: found_only })

  # Summary
  println ""
  let summary = show final.passed <> " passed, " <> show final.failed <> " failed"
  let summary = if final.skipped > 0 then summary <> ", " <> show final.skipped <> " skipped"
                else summary
  println summary
  if final.failed > 0 then Process.exit 1 else ()
}

# Assertion helpers

pub fun assert_eq : (a: x) -> (b: x) -> Unit needs {Assert} where {x: Debug + Eq}
assert_eq a b =
  if a == b then assert! True ""
  else assert! False ("Expected " <> debug b <> ", got " <> debug a)

pub fun assert_neq : (a: x) -> (b: x) -> Unit needs {Assert} where {x: Debug + Eq}
assert_neq a b =
  if a != b then assert! True ""
  else assert! False ("Expected " <> debug a <> " to not equal " <> debug b)

pub fun assert_gt : (a: x) -> (b: x) -> Unit needs {Assert} where {x: Debug + Ord}
assert_gt a b =
  assert! (a > b) ("Expected " <> debug a <> " > " <> debug b)

pub fun assert_lt : (a: x) -> (b: x) -> Unit needs {Assert} where {x: Debug + Ord}
assert_lt a b =
  assert! (a < b) ("Expected " <> debug a <> " < " <> debug b)
