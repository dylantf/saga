module Std.Test

pub effect Assert {
  fun assert (ok: Bool) (msg: String) -> Unit
}

pub effect TestRunner {
  fun pass (name: String) -> Unit
  fun fail (name: String) (msg: String) -> Unit
}

#@ Runs a named test. Collects all assertion failures via multi-shot
#@ continuations, then reports pass/fail through the TestRunner effect.
pub fun test (name: String) (body: () -> Unit needs {Assert}) -> Unit needs {TestRunner}
test name body = {
  let (_, failures) = { body () } with {
    assert ok msg =
      if ok then {
        let (val, errs) = resume ()
        (val, errs)
      } else {
        let (val, errs) = resume ()
        (val, msg :: errs)
      }
    return val = (val, [])
  }
  case failures {
    [] -> pass! name
    h :: _ -> fail! name h
  }
}

#@ Groups tests under a label.
pub fun describe (name: String) (body: () -> Unit needs {TestRunner}) -> Unit needs {TestRunner}
describe name body = body ()

# --- Assertion helpers ---

pub fun assert_eq (a: x) (b: x) -> Unit needs {Assert} where {x: Show + Eq}
assert_eq a b =
  if a == b then assert! True ""
  else assert! False ("Expected " <> show b <> ", got " <> show a)

pub fun assert_neq (a: x) (b: x) -> Unit needs {Assert} where {x: Show + Eq}
assert_neq a b =
  if a != b then assert! True ""
  else assert! False ("Expected " <> show a <> " to not equal " <> show b)

pub fun assert_true (cond: Bool) -> Unit needs {Assert}
assert_true cond = assert! cond "Expected True, got False"

pub fun assert_false (cond: Bool) -> Unit needs {Assert}
assert_false cond =
  if cond then assert! False "Expected False, got True"
  else assert! True ""

pub fun assert_gt (a: x) (b: x) -> Unit needs {Assert} where {x: Show + Ord}
assert_gt a b =
  assert! (a > b) ("Expected " <> show a <> " > " <> show b)

pub fun assert_lt (a: x) (b: x) -> Unit needs {Assert} where {x: Show + Ord}
assert_lt a b =
  assert! (a < b) ("Expected " <> show a <> " < " <> show b)
