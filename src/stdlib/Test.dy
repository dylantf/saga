module Std.Test

import Std.Base
import Std.IO (Stdio, println, console)
import Std.Process
import Std.List
import Std.String
import Std.Time (monotonic_ms)

pub effect Assert {
  fun assert : (ok: Bool) -> (msg: String) -> Unit
}

type TestMode = Normal | OnlyMode | SkipMode

type TestEntry  =
  | TestCase(String, TestMode) 
  | GroupStart(String) 
  | GroupEnd

pub effect TestRunner {
  fun report_test : (name: String) -> (failures: List String) -> (mode: TestMode) -> (elapsed_ms: Int) -> Unit
  fun enter_group : (name: String) -> Unit
  fun leave_group : Unit -> Unit
}

record TestState {
  passed: Int,
  failed: Int,
  skipped: Int,
  depth: Int,
  has_only: Bool,
  start_time: Int,
}

fun indent : (n: Int) -> (s: String) -> String
indent n s = String.repeat n "  " <> s

fun format_timing : Int -> String
format_timing ms =
  if ms == 0 then "\x1b[2m(<1ms)\x1b[0m"
  else $"\x1b[2m({show ms}ms)\x1b[0m"

fun run_body : (body: Unit -> Unit needs {Assert, ..e}) -> List String needs {..e}
run_body body = {
  let (_, failures) = { body () } with {
    assert ok msg =
      if ok then {
        let (v, errs) = resume ()
        (v, errs)
      } else {
        let (v, errs) = resume ()
        (v, msg :: errs)
      }
    return v = (v, [])
  }
  failures
}

#@ Run a test.
pub fun test : (name: String) -> (body: Unit -> Unit needs {Assert, ..e}) -> Unit needs {TestRunner, ..e}
test name body = {
  let t0 = monotonic_ms ()
  let failures = run_body body
  let elapsed = monotonic_ms () - t0
  report_test! name failures Normal elapsed
}

#@ Run a focused test. When any test uses `only`, all other tests are skipped.
pub fun only : (name: String) -> (body: Unit -> Unit needs {Assert, ..e}) -> Unit needs {TestRunner, ..e}
only name body = {
  let t0 = monotonic_ms ()
  let failures = run_body body
  let elapsed = monotonic_ms () - t0
  report_test! name failures OnlyMode elapsed
}

#@ Skip a test. The body is never executed.
pub fun skip : (name: String) -> (body: Unit -> Unit needs {Assert, ..e}) -> Unit needs {TestRunner, ..e}
skip name _body = report_test! name [] SkipMode 0

#@ Group tests under a label.
pub fun describe : (name: String) -> (body: Unit -> Unit needs {TestRunner, ..e}) -> Unit needs {TestRunner, ..e}
describe name body = {
  enter_group! name
  body ()
  leave_group! ()
}

#@ Collecting handler (pass 1). Records test entries, discards results.
handler collect_handler for TestRunner {
  report_test name _failures mode _elapsed = {
    let k = resume ()
    fun entries -> k (TestCase(name, mode) :: entries)
  }
  enter_group name = {
    let k = resume ()
    fun entries -> k (GroupStart(name) :: entries)
  }
  leave_group () = {
    let k = resume ()
    fun entries -> k (GroupEnd :: entries)
  }
  return _ = fun entries -> entries
}

#@ Executing handler (pass 2). Renders results, skips non-only tests if has_only is set.
pub handler exec_handler for TestRunner needs {Stdio} {
  report_test name failures mode elapsed_ms = {
    let k = resume ()
    fun state -> {
      let d = state.depth
      let timing = " " <> format_timing elapsed_ms
      let should_skip = case mode {
        SkipMode -> True
        Normal -> state.has_only
        OnlyMode -> False
      }
      if should_skip then {
        println (indent d $"\x1b[33m○\x1b[0m {name} (skipped)")
        k { state | skipped: state.skipped + 1 }
      } else {
        case failures {
          [] -> {
            println (indent d $"\x1b[32m✓\x1b[0m {name}{timing}")
            k { state | passed: state.passed + 1 }
          }
          h :: _ -> {
            println (indent d $"\x1b[31m✗\x1b[0m {name}{timing}")
            println (indent d $"    {h}")
            k { state | failed: state.failed + 1 }
          }
        }
      }
    }
  }
  enter_group name = {
    let k = resume ()
    fun state -> {
      println (indent state.depth name)
      k { state | depth: state.depth + 1 }
    }
  }
  leave_group () = {
    let k = resume ()
    fun state -> k { state | depth: state.depth - 1 }
  }
  return _ = fun state -> state
}

fun reverse_entries : (acc: List TestEntry) -> (xs: List TestEntry) -> List TestEntry
reverse_entries acc xs = case xs {
  [] -> acc
  h :: t -> reverse_entries (h :: acc) t
}

fun has_only_entry : TestEntry -> Bool
has_only_entry entry = case entry {
  TestCase(_, OnlyMode) -> True
  _ -> False
}

#@ Run a test suite with two-pass collect-then-execute.
#@ Pass 1 collects test metadata to check for `only`.
#@ Pass 2 executes, skipping non-only tests if any only was found.
pub fun run_collected : (body: Unit -> Unit needs {TestRunner, ..e}) -> Unit needs {..e}
run_collected body = {
  let suite_start = monotonic_ms ()

  # Pass 1: collect entries (bodies run but results discarded)
  let entries_fn = { body () } with collect_handler
  let entries = reverse_entries [] (entries_fn [])
  let found_only = List.any has_only_entry entries

  # Pass 2: execute for real
  let state_fn = { body () } with exec_handler
  let final = state_fn (TestState { passed: 0, failed: 0, skipped: 0, depth: 0, has_only: found_only, start_time: suite_start })

  let total_ms = monotonic_ms () - suite_start

  # Summary
  println ""
  let summary = $"{final.passed} passed, {final.failed} failed"
  let summary = if final.skipped > 0 then $"{summary}, {final.skipped} skipped"
                else summary
  println $"{summary} {format_timing total_ms}"
  if final.failed > 0 then Process.exit 1 else ()
} with console

# Assertion helpers

pub fun assert_eq : (a: x) -> (b: x) -> Unit needs {Assert} where {x: Debug + Eq}
assert_eq a b =
  if a == b then assert! True ""
  else assert! False $"Expected {debug b}, got {debug a}"

pub fun assert_neq : (a: x) -> (b: x) -> Unit needs {Assert} where {x: Debug + Eq}
assert_neq a b =
  if a != b then assert! True ""
  else assert! False $"Expected {debug a} to not equal {debug b}"

pub fun assert_gt : a -> a -> Unit needs {Assert} where {a: Debug + Ord}
assert_gt a b =
  assert! (a > b) $"Expected {debug a} > {debug b}"

pub fun assert_lt : (a: x) -> (b: x) -> Unit needs {Assert} where {x: Debug + Ord}
assert_lt a b =
  assert! (a < b) ("Expected " <> debug a <> " < " <> debug b)

#@ Assert that a boolean value is True.
pub fun assert_true : Bool -> Unit needs {Assert}
assert_true v = assert! v "Expected True, got False"

#@ Assert that a boolean value is False.
pub fun assert_false : Bool -> Unit needs {Assert}
assert_false v = assert! (v == False) "Expected False, got True"

#@ Assert that a Maybe value is Just (contains a value).
pub fun assert_just : Maybe a -> Unit needs {Assert} where {a: Debug}
assert_just m = case m {
  Just _ -> assert! True ""
  Nothing -> assert! False "Expected Just(_), got Nothing"
}

#@ Assert that a Maybe value is Nothing.
pub fun assert_nothing : Maybe a -> Unit needs {Assert}
assert_nothing m = case m {
  Nothing -> assert! True ""
  Just _ -> assert! False "Expected Nothing, got Just(_)"
}

#@ Assert that a Result value is Ok.
pub fun assert_ok : Result a b -> Unit needs {Assert} where {b: Debug}
assert_ok r = case r {
  Ok _ -> assert! True ""
  Err e -> assert! False $"Expected Ok(_), got Err({debug e})"
}

#@ Assert that a Result value is Err.
pub fun assert_err : Result a b -> Unit needs {Assert} where {a: Debug}
assert_err r = case r {
  Ok v -> assert! False $"Expected Err(_), got Ok({debug v})"
  Err _ -> assert! True ""
}

#@ Assert that a function panics when called.
pub fun assert_panics : (f: Unit -> a) -> Unit needs {Assert}
assert_panics f = case Process.catch_panic f {
  Err _ -> assert! True ""
  Ok _ -> assert! False "Expected a panic, but none occurred"
}
