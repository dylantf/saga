module Std.Float

impl Show for Float {
  show x = to_string x
}

impl Debug for Float {
  debug x = to_string x
}

@external("erlang", "erlang", "float_to_list")
fun to_string : (x: Float) -> String

pub @external("erlang", "erlang", "trunc")
fun trunc : (x: Float) -> Int

pub @external("erlang", "erlang", "round")
fun round : (x: Float) -> Int

pub @external("erlang", "erlang", "floor")
fun floor : (x: Float) -> Int

pub @external("erlang", "erlang", "ceil")
fun ceil : (x: Float) -> Int
