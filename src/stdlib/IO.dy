module Std.IO

import Std.String

#@ prints to stdout
pub fun print (x: String) -> Unit
# builtin

#@ prints to stdout with a trailing newline
pub fun println (x: String) -> Unit
# builtin

#@ prints to stderr
pub fun eprint (x: String) -> Unit
# builtin

#@ prints to stderr with a trailing newline
pub fun eprintln (x: String) -> Unit
# builtin