module Std.IO

import Std.String

#@ prints to stdout
@builtin
pub fun print : String -> Unit

#@ prints to stdout with a trailing newline
@builtin
pub fun println : String -> Unit

#@ prints to stderr
@builtin
pub fun eprint : String -> Unit

#@ prints to stderr with a trailing newline
@builtin
pub fun eprintln : String -> Unit

#@ prints debug representation to stderr and returns the value
@builtin
pub fun dbg : a -> a where {a: Debug}
