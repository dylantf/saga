## This is not implmented! Just a sketch...

trait Functor (f: * -> *) {
  fun map : (func: a -> b) -> (fa: f a) -> f b
}

trait Applicative (f: * -> *) where {f: Functor} {
  fun pure : (x: a) -> f a
  fun ap : (ff: f (a -> b)) -> (fa: f a) -> f b
}

type Validation e a {
  Valid(a)
  Invalid(e)
}

impl Functor for Validation e {
  map f v = case v {
    Valid(x)      -> Valid(f x)
    Invalid(errs) -> Invalid(errs)
  }
}

impl Applicative for Validation e {
  pure x = Valid(x)
  ap ff fa = case ff {
    Valid(f) -> case fa {
      Valid(v)      -> Valid(f v)
      Invalid(errs) -> Invalid(errs)
    }
    Invalid(e1) -> case fa {
      Valid(_)      -> Invalid(e1)
      Invalid(e2)   -> Invalid(append e1 e2)
    }
  }
}

# --- Validators ---

require_non_empty label s =
  if s == "" then Invalid([$"{label} is required"])
  else Valid(s)

require_min_age min age =
  if age < min then Invalid([$"age must be at least {min}"])
  else Valid(age)

# --- Domain types ---

record UserInput {
  name: String,
  age: Int,
}

record ValidUser {
  name: String,
  age: Int,
}

fun validate_user : (input: UserInput) -> Validation (List String) ValidUser
validate_user input =
  map (fun n -> fun a -> ValidUser { name: n, age: a })
      (require_non_empty "name" input.name)
  <*> require_min_age 18 input.age

# --- Display ---

show_errors errs = foldl (fun acc e -> acc <> $"\n  - {e}") "" errs

fun show_result : (r: Validation (List String) ValidUser) -> String
show_result r = case r {
  Valid(user)   -> $"Valid: {user.name}, age {user.age}"
  Invalid(errs) -> $"Invalid: {show_errors errs}"
}

# --- Main ---

main () = {
  validate_user UserInput { name: "Alice", age: 25 } |> show_result |> println
  validate_user UserInput { name: "", age: 25 } |> show_result |> println
  validate_user UserInput { name: "Bob", age: 15 } |> show_result |> println
  validate_user UserInput { name: "", age: 15 } |> show_result |> println
}
